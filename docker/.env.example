# =============================================
# CPA Daily 环境变量配置
# 使用方式: 复制为 .env 并修改
#   cp .env.example .env
#   vim .env
# =============================================

# MySQL密码
MYSQL_ROOT_PASSWORD=cpa@2026

# ====== AI模型配置（选一个填上即可） ======

# 当前使用的AI模型
# 可选: openai / claude / qwen / deepseek / zhipu / doubao / ollama
CPA_AI_MODEL=qwen

# 阿里 通义千问（推荐国内用户，便宜好用）
# 获取: https://dashscope.console.aliyun.com/
AI_QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx

# DeepSeek
# 获取: https://platform.deepseek.com/
AI_DEEPSEEK_API_KEY=

# 智谱GLM
# 获取: https://open.bigmodel.cn/
AI_ZHIPU_API_KEY=

# 豆包（字节跳动）
# 获取: https://console.volcengine.com/ark
AI_DOUBAO_API_KEY=

# OpenAI
AI_OPENAI_API_KEY=

# Anthropic Claude
AI_CLAUDE_API_KEY=
